// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  role          UserRole  @default(VIEWER)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  recoveryCodes    String[] // hashed recovery codes
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)

  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  loginHistory  LoginHistory[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  success    Boolean
  failReason String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_history")
}

// ==================== CORE MODELS ====================

model Province {
  id        String   @id @default(cuid())
  name      String   @unique
  nameNp    String?  // Nepali name
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  districts District[]

  @@map("provinces")
}

model District {
  id         String   @id @default(cuid())
  name       String
  nameNp     String?  // Nepali name
  slug       String   @unique
  provinceId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  province     Province      @relation(fields: [provinceId], references: [id])
  districtRates DistrictRate[]

  @@map("districts")
}

model FiscalYear {
  id        String   @id @default(cuid())
  year      String   @unique // e.g., "2083-84"
  yearAd    String?  // e.g., "2026-27"
  isCurrent Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  districtRates DistrictRate[]

  @@map("fiscal_years")
}

model DistrictRate {
  id           String            @id @default(cuid())
  districtId   String
  fiscalYearId String
  slug         String            @unique // e.g., "panchthar-2083-84"
  pdfUrl       String            // Cloudflare R2 or similar
  pdfSize      Int?              // bytes
  pdfPages     Int?
  status       PublicationStatus @default(DRAFT)
  publishedAt  DateTime?
  downloadCount Int              @default(0)
  viewCount    Int               @default(0)
  description  String?           @db.Text
  // SEO
  seoTitle     String?
  seoDescription String?
  // Meta
  uploadedBy   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  district     District   @relation(fields: [districtId], references: [id])
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])
  downloads    Download[]
  searchLogs   SearchLog[]

  @@unique([districtId, fiscalYearId])
  @@map("district_rates")
}

model Download {
  id             String   @id @default(cuid())
  districtRateId String
  ipAddress      String?
  userAgent      String?
  referer        String?
  createdAt      DateTime @default(now())

  districtRate DistrictRate @relation(fields: [districtRateId], references: [id], onDelete: Cascade)

  @@map("downloads")
}

model SearchLog {
  id             String   @id @default(cuid())
  query          String
  province       String?
  fiscalYear     String?
  resultsCount   Int      @default(0)
  clickedId      String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  clicked DistrictRate? @relation(fields: [clickedId], references: [id], onDelete: SetNull)

  @@map("search_logs")
}

// ==================== CONTACT MODEL ====================

model ContactInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  type      InquiryType   @default(GENERAL)
  districtRateId String?  // if requesting specific district format
  status    InquiryStatus @default(NEW)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contact_inquiries")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ==================== SITE CONFIG ====================

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string") // string, json, boolean, number
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

// ==================== FUTURE MODULES (Placeholder Tables) ====================
// These are intentionally minimal stubs to reserve the namespace

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("blog_posts")
}

model Vacancy {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("vacancies")
}

// ==================== ENUMS ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InquiryType {
  GENERAL
  WORD_FORMAT
  EXCEL_FORMAT
  EDITABLE_FORMAT
  CUSTOM_REQUEST
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}
