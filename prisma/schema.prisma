generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  emailVerified    DateTime?
  password         String?
  name             String?
  image            String?
  role             UserRole       @default(VIEWER)
  twoFactorEnabled Boolean        @default(false)
  twoFactorSecret  String?
  recoveryCodes    String[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  lastLoginAt      DateTime?
  isActive         Boolean        @default(true)
  accounts         Account[]
  auditLogs        AuditLog[]
  loginHistory     LoginHistory[]
  sessions         Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  success    Boolean
  failReason String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_history")
}

model Province {
  id        String     @id @default(cuid())
  name      String     @unique
  nameNp    String?
  slug      String     @unique
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  districts District[]

  @@map("provinces")
}

model District {
  id            String         @id @default(cuid())
  name          String
  nameNp        String?
  slug          String         @unique
  provinceId    String
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  districtRates DistrictRate[]
  province      Province       @relation(fields: [provinceId], references: [id])

  @@map("districts")
}

model FiscalYear {
  id            String         @id @default(cuid())
  year          String         @unique
  yearAd        String?
  isCurrent     Boolean        @default(false)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  districtRates DistrictRate[]

  @@map("fiscal_years")
}

model DistrictRate {
  id             String            @id @default(cuid())
  districtId     String
  fiscalYearId   String
  slug           String            @unique
  pdfUrl         String
  pdfSize        Int?
  pdfPages       Int?
  status         PublicationStatus @default(DRAFT)
  publishedAt    DateTime?
  downloadCount  Int               @default(0)
  viewCount      Int               @default(0)
  description    String?
  seoTitle       String?
  seoDescription String?
  uploadedBy     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  district       District          @relation(fields: [districtId], references: [id])
  fiscalYear     FiscalYear        @relation(fields: [fiscalYearId], references: [id])
  downloads      Download[]
  searchLogs     SearchLog[]

  @@unique([districtId, fiscalYearId])
  @@map("district_rates")
}

model Download {
  id             String       @id @default(cuid())
  districtRateId String
  ipAddress      String?
  userAgent      String?
  referer        String?
  createdAt      DateTime     @default(now())
  districtRate   DistrictRate @relation(fields: [districtRateId], references: [id], onDelete: Cascade)

  @@map("downloads")
}

model SearchLog {
  id           String        @id @default(cuid())
  query        String
  province     String?
  fiscalYear   String?
  resultsCount Int           @default(0)
  clickedId    String?
  ipAddress    String?
  createdAt    DateTime      @default(now())
  clicked      DistrictRate? @relation(fields: [clickedId], references: [id])

  @@map("search_logs")
}

model ContactInquiry {
  id             String        @id @default(cuid())
  name           String
  email          String
  phone          String?
  subject        String
  message        String
  type           InquiryType   @default(GENERAL)
  districtRateId String?
  status         InquiryStatus @default(NEW)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("contact_inquiries")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

model Vacancy {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vacancies")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InquiryType {
  GENERAL
  WORD_FORMAT
  EXCEL_FORMAT
  EDITABLE_FORMAT
  CUSTOM_REQUEST
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}
